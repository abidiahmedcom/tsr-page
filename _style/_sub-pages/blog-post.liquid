@import url('../_components/global.css');
@import url('../_components/palette.css');

.title {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
}

.blog-post-title {
    font-size: var(--h2);
    font-weight: 300;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

/* Tags section */
.blog-post-tags {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
}

.tags {
    padding: 0.3rem 1rem;
    color: var(--text-primary);
}