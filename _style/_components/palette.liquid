/* Color Palettes */
:root {
    --bg-primary: #1a1a1a;
    --bg-secondary: #1F1F1F;
    --text-primary: #ffffff;
    --text-secondary: #b0b0b0;
    --border-color: #3a3a3a;
    --accent-color: #09A85A;
    --bg-code: rgba(9, 168, 90, 0.1);
}

[data-theme="light"] {
    --bg-primary: #ffffff;
    --bg-secondary: #ebebeb;
    --text-primary: #1a1a1a;
    --text-secondary: #4a4a4a;
    --border-color: #e0e0e0;
    --accent-color: #ff8000;
    --bg-code: rgba(255, 128, 0, 0.1);
}

:root {
    /* Typography */
    --h1: 3rem;
    --h2: 2.5rem;
    --h3: 1.5rem;
    --h4: 1.2rem;
    --regular: 1rem;
    --small: 0.9rem;
    --very-small: 0.8rem;

    /* Contact Size */
    --big-icon: 3rem;
    --small-icon: 2.5rem;
    --very-small-icon: 1.2rem;
}