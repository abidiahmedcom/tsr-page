---
permalink: /_style/about.css
---

@import url('_components/global.css');
@import url('_components/palette.css');

.first_name {
    font-size: var(--h1);
    color: var(--text-primary);
    font-weight: 500;
    margin: 0;
    line-height: 1;
    padding: 0.5rem 0;
}

.last_name,
.middle_name {
    color: var(--text-primary);
    font-weight: 300;
}

.tagline {
    margin: 0;
    margin-bottom: 1rem;
}

.tagline a {
    color: var(--accent-color);
    text-decoration: none;
    transition: var(--transition);
}

.tagline a:hover {
    text-decoration: underline;
}

.logo {
    visibility: hidden;
}

/* About Content */
.content {
    display: flow-root;
}

.content img {
    max-width: 250px;
}

.profile-picture {
    float: right;
    margin: 0 0 0 30px;
}

.profile-caption {
    color: var(--text-secondary);
    font-family: 'Courier', monospace;
    text-align: center;
    margin-top: 0.5rem;
    max-width: 250px;
}

.content p {
    text-align: justify;
    font-size: var(--regular);
    margin-top: 0;
    margin-bottom: 1rem;
    text-align: left;
    color: var(--text-primary);
}

.content strong,
.content b {
    font-weight: 500;
}

.content a {
    font-size: var(--regular);
    color: var(--accent-color);
    text-decoration: none;
    transition: var(--transition);
}

.content a:hover {
    text-decoration: underline;
}

.content code {
    background-color: var(--bg-code);
    color: var(--accent-color);
    padding: 0.2rem;
    border-radius: 2px;
    font-family: 'roboto', monospace;
}


/* projects, blog & papers*/
.features {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
}

.feature-title {
    font-size: var(--h2);
    margin-bottom: 2rem;
    font-weight: 300;
}

.blog-title, .project-title {
    font-size: var(--h4);
    font-weight: 300;   
    margin: 0 0 0.5rem 0;
}

.paper-title {
    font-size: var(--h4);
    font-weight: 300;   
    margin: 0;
}

.blog-title a {
    font-size: var(--regular);
    color: var(--accent-color);
    text-decoration: none;
    transition: var(--transition);
}

.blog-title a:hover {
    text-decoration: underline;
}

.blog-card, .paper-card, .project-card {
    padding-bottom: 1rem;
}

.paper-card-meta, .project-card-meta, .blog-card-meta{
    display: flex;
    gap: 1rem;
    margin: 0 0 0.5rem 0;
}

.paper-card-meta {
    align-items: center;
}

.project-card-meta, .blog-card-meta {
    align-items: baseline;
    margin: 0;
}

.paper-tag {
    background-color: var(--paper-tag-bg, var(--accent-color));
    color: var(--paper-tag-color, var(--text-primary));
    font-size: var(--very-small);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.7rem;
    border-radius: 2px;
    font-family: 'Courier', monospace;
}

.paper-date {
    font-size: var(--regular);
    color: var(--text-secondary);
    /* font-family: 'roboto', monospace; */
    margin: 0 0 0.5rem 0;
}

.description {
    margin-top: 0;
    font-size: var(--regular);
    /* margin-bottom: 0.5rem; */
    color: var(--text-primary);
}

.news-card::before {
    content: '•';
}

.news-date {
    font-size: var(--regular);
    font-weight: 500;
    margin-right: 1rem;
}

.blog-date {
    font-weight: 300;
}

@media (max-width: 768px) {}

@media (max-width: 674px) {

    .content {
        margin-bottom: 2rem;
    }

    .content img {
        margin-top: 1rem;
        max-width: 100%;
    }

    .profile-picture {
        float: none;
        margin: 0 auto;
        display: block;
    }

    .profile-caption {
        max-width: 100%;
    }
}